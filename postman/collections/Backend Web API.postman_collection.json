        {
          "name": "Crear rol",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 or 201\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const statusCode = pm.response.code;",
                  "",
                  "if (statusCode === 200 || statusCode === 201) {",
                  "    pm.test(\"Response body is a JSON object with an 'id' property\", function () {",
                  "        const jsonData = pm.response.json();",
                  "        pm.expect(jsonData).to.be.an(\"object\");",
                  "        pm.expect(jsonData).to.have.property(\"id\");",
                  "    });",
                  "} else if (statusCode === 400) {",
                  "    console.log(\"Bad request - check the request body fields: nombre, descripcion, empresaId.\");",
                  "} else if (statusCode === 404) {",
                  "    console.log(\"Not found - check that the endpoint /api/roles exists and the empresaId is valid.\");",
                  "} else if (statusCode === 500) {",
                  "    console.log(\"Server error - the backend may have a bug or the empresaId may not exist in the database.\");",
                  "}"
                ],
